# Comadre Mobile — Environment Variables
#
# Copy this file to .env and fill in the values.
# All keys prefixed with EXPO_PUBLIC_ are embedded at build time.

# Backend API base URL (include /api/v1 path)
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# Privy App ID from https://dashboard.privy.io
EXPO_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Set to "true" to use mock data (no backend required)
EXPO_PUBLIC_USE_MOCK=true
