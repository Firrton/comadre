{
  "expo": {
    "name": "Comadre",
    "slug": "comadre",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "comadre",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "lat.comadre.app"
    },
    "android": {
      "package": "lat.comadre.app",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "comadre",
              "host": "join",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
