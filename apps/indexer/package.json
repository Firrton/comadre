    "@comadre/types": "workspace:*",
    "@coral-xyz/anchor": "^0.31.0",
    "@solana/web3.js": "^1.98.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  }
