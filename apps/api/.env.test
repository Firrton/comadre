# Test environment — stub values for unit tests
# All services that aren't needed for unit tests get placeholder values.
NODE_ENV=test
LOG_LEVEL=warn
SKIP_REDIS=true

# Solana
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
COMADRE_PROGRAM_ID=CMDRxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Wallets (base58 stubs — invalid keys, only used for env validation)
FEE_PAYER_SK=11111111111111111111111111111111
CRANK_AUTHORITY_SK=11111111111111111111111111111111
KYC_ORACLE_SK=11111111111111111111111111111111
ADMIN_SK=11111111111111111111111111111111

# Privy
PRIVY_APP_ID=test-app-id
PRIVY_APP_SECRET=test-app-secret
PRIVY_VERIFICATION_KEY=test-verification-key

# Sumsub
SUMSUB_APP_TOKEN=test-sumsub-token
SUMSUB_SECRET_KEY=test-sumsub-secret
SUMSUB_WEBHOOK_SECRET=test-webhook-secret

# Meta WhatsApp (pivot may replace with Twilio; stub for now)
META_APP_SECRET=test-meta-secret
META_PHONE_NUMBER_ID=test-phone-id
META_ACCESS_TOKEN=test-access-token
META_VERIFY_TOKEN=test-verify-token
META_WABA_ID=test-waba-id

# Anthropic (pivot may replace with Kimi; stub for now)
ANTHROPIC_API_KEY=test-anthropic-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# Helius
HELIUS_API_KEY=test-helius-key
HELIUS_WEBHOOK_SECRET=test-helius-secret

# Postgres (stub URL — DB calls will fail in pure unit tests, which is expected)
DATABASE_URL=postgresql://test:test@localhost:5432/test
DIRECT_URL=postgresql://test:test@localhost:5432/test

# Upstash Redis (stub — cache calls will fail in unit tests without a real instance)
UPSTASH_REDIS_REST_URL=https://test.upstash.io
UPSTASH_REDIS_REST_TOKEN=test-redis-token

# Internal
INTERNAL_HMAC_SECRET=test-hmac-secret-at-least-32-chars-long

# Service URLs
API_URL=http://localhost:3001
WA_URL=http://localhost:3002
AGENT_URL=http://localhost:3003
INDEXER_URL=http://localhost:3004
