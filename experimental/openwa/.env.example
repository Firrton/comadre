# ============================================================
# TEMPORARY SANDBOX — do not use in production
# Copy to .env before running: cp .env.example .env
# .env is gitignored — never commit it
# ============================================================

# ---- Host port for the OpenWA API (build-time and runtime) ----
# The container always listens on 2785; this maps it to the host.
OPENWA_PORT=3005

# ---- Build-time: which OpenWA commit/branch/tag to clone ----
# Pinned to a specific SHA for reproducible builds.
# SHA 0fbee7fbee9d746050a20c57544bf7bbb80e65d2 = HEAD of main, 2026-06-11.
# Update when you need a newer upstream version.
OPENWA_REF=0fbee7fbee9d746050a20c57544bf7bbb80e65d2

# ---- OpenWA core config ----
# Engine — do not change; only whatsapp-web.js is supported here
ENGINE_TYPE=whatsapp-web.js

# API master key — set a strong random value to protect the REST API.
# Leave empty to disable auth (not recommended even for local testing).
API_MASTER_KEY=changeme-replace-with-random-secret

# Allowed CORS origins (comma-separated). Keep restrictive.
CORS_ORIGINS=http://localhost:3000,http://localhost:3005

# ---- Session / storage ----
# Path INSIDE the container where sessions are stored.
# The docker-compose volume mounts ./sessions → this path.
SESSION_DATA_PATH=/app/data/sessions

# Local media storage path inside the container.
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/data/media

# ---- Database (SQLite by default — no extra service needed) ----
DATABASE_TYPE=sqlite
DATABASE_NAME=openwa
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false

# ---- Redis (disabled by default) ----
# Set REDIS_ENABLED=true and add a redis service in compose if you
# need BullMQ queues for high-volume message processing.
REDIS_ENABLED=false
REDIS_HOST=openwa-redis
REDIS_PORT=6379

# ---- Puppeteer / Chromium ----
PUPPETEER_HEADLESS=true
# These args are required when running inside Docker (no sandbox).
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu

# ---- Webhook (future bridge to apps/agent) ----
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# ---- Logging ----
LOG_LEVEL=info
