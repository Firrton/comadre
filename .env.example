# ============================================================
# Comadre — environment variables (sample)
# Copy to .env.local and fill with real values. NEVER commit .env.local
# ============================================================

# === Monad chain ===
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
COMADRE_CONTRACT_ADDRESS=
# Neverland's USDC on Monad mainnet (may differ from canonical Monad USDC)
USDC_CONTRACT_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603

# === Neverland (Aave V3 fork — USDC yield) ===
# Verified addresses on Monad mainnet (https://docs.neverland.money/smart-contracts)
NEVERLAND_POOL_ADDRESS=0x80F00661b13CC5F6ccd3885bE7b4C9c67545D585
NEVERLAND_POOL_ADDRESSES_PROVIDER=0x49D75170F55C964dfdd6726c74fdEDEe75553A0f
NEVERLAND_UI_POOL_DATA_PROVIDER=0x0733e79171dd5A5E8aF41E387c6299bCfE6a7e55
NEVERLAND_N_USDC_ADDRESS=0x38648958836eA88b368b4ac23b86Ad44B0fe7508
NEVERLAND_DUST_REWARDS_CONTROLLER=0x57ea245cCbFAb074baBb9d01d1F0c60525E52cec

# === Comadre yield model ===
# Performance fee on user yield only (not principal). 2000 = 20.00%.
COMADRE_YIELD_FEE_BPS=2000
# Daily aggregate spend cap per sender (trailing 24h window). Integer USDC. Default: 100.
# DAILY_AGGREGATE_CAP_USDC=100
# Wallet that receives the 20% performance fee. Must be a Turnkey-managed wallet under Comadre org control.
# Example: 0x... (set in prod; can be empty in dev)
COMADRE_FEE_WALLET=

# --- Pimlico (ERC-4337 bundler) ---
PIMLICO_API_KEY=
PIMLICO_BUNDLER_URL=
PIMLICO_PAYMASTER_ENABLED=false

# --- Privy (user embedded EVM wallet + JWT auth) ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=

# --- Turnkey (session key HSM custody) ---
# Create API keys at app.turnkey.com → Settings → API Keys
# Required in production; optional in dev (signing flows fail without them)
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=

# --- Sumsub KYC ---
# REST API integration (level: id-and-liveness)
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=

# --- OpenWA self-hosted WhatsApp bridge ---
# The OpenWA container (experimental/openwa) exposes a REST API on host 3005.
# OPENWA_API_KEY == the API key shown in the container startup banner
#   (dev mode default: 'dev-admin-key'; production: set to the owa_k1_* key).
# OPENWA_WEBHOOK_SECRET signs inbound deliveries (X-OpenWA-Signature, HMAC-SHA256);
# it is DISTINCT from INTERNAL_HMAC_SECRET — never reuse.
OPENWA_API_URL=http://localhost:3005
OPENWA_API_KEY=
OPENWA_SESSION_ID=comadre
OPENWA_WEBHOOK_SECRET=

# --- LLM provider (Kimi K2) ---
# Pick one of moonshot or groq via LLM_PROVIDER. Both keys can coexist.
#   moonshot: direct API to Moonshot. Real model IDs: kimi-k2.5 or kimi-k2.6
#   groq:     same Kimi model on Groq's infra, KIMI_MODEL=moonshotai/kimi-k2-instruct
# Note: kimi-k2.6 is a reasoning model — Moonshot enforces temperature=1 for it.
LLM_PROVIDER=moonshot
MOONSHOT_API_KEY=
GROQ_API_KEY=
KIMI_MODEL=kimi-k2.6

# --- Database (Supabase Postgres recommended) ---
# Use `?pgbouncer=true&connection_limit=1` on DATABASE_URL for serverless.
# DIRECT_URL bypasses pgbouncer for migrations (drizzle-kit).
DATABASE_URL=postgresql://user:pass@localhost:5432/comadre
DIRECT_URL=postgresql://user:pass@localhost:5432/comadre

# --- Redis (Upstash REST) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Internal auth (service-to-service HMAC) ---
# Generate with: openssl rand -hex 32
INTERNAL_HMAC_SECRET=

# --- Contact encryption (AES-256-GCM key for phone storage) ---
# Required in ALL environments; minimum 32 chars (audit MED-9).
# Generate with: openssl rand -hex 32
CONTACT_ENCRYPTION_KEY=

# --- Magic-link onboarding ---
# Base URL where the browser opens the magic link (apps/web)
ONBOARDING_BASE_URL=http://localhost:3000

# --- Service URLs (internal mesh) ---
API_URL=http://localhost:3001
WA_URL=http://localhost:3002
AGENT_URL=http://localhost:3003

# --- Observability (optional) ---
SENTRY_DSN=
BETTER_STACK_TOKEN=

# --- Dev tooling (optional) ---
# ngrok for exposing local services during dev
NGROK_AUTH_TOKEN=

# --- App ---
NODE_ENV=development
LOG_LEVEL=debug
