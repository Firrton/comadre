# ============================================================
# Comadre — environment variables (sample)
# Copy to .env.local and fill with real values. NEVER commit .env.local
# ============================================================

# --- Solana ---
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
COMADRE_PROGRAM_ID=
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- Wallets (base58 secret keys) ---
FEE_PAYER_SK=
CRANK_AUTHORITY_SK=
KYC_ORACLE_SK=
ADMIN_SK=

# --- Privy ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=

# --- Sumsub ---
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=

# --- Meta WhatsApp Cloud API ---
META_APP_SECRET=
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_WABA_ID=

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- ElevenLabs (Fase 2) ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# --- Helius ---
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/comadre
DIRECT_URL=postgresql://user:pass@localhost:5432/comadre

# --- Redis (Upstash) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Internal auth ---
INTERNAL_HMAC_SECRET=

# --- Service URLs (internal) ---
API_URL=http://localhost:3001
WA_URL=http://localhost:3002
AGENT_URL=http://localhost:3003
INDEXER_URL=http://localhost:3004

# --- Observability ---
SENTRY_DSN=
BETTER_STACK_TOKEN=

# --- App ---
NODE_ENV=development
LOG_LEVEL=debug
