# ============================================================
# Comadre — environment variables (sample)
# Copy to .env.local and fill with real values. NEVER commit .env.local
# ============================================================

# --- Solana ---
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
COMADRE_PROGRAM_ID=
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# --- Wallets (base58 secret keys) ---
# Generate with `solana-keygen new -o keypairs/<name>.json --no-bip39-passphrase`
# then convert with `bun run scripts/keypair-to-sk.ts keypairs/<name>.json`
FEE_PAYER_SK=
CRANK_AUTHORITY_SK=
KYC_ORACLE_SK=
ADMIN_SK=

# --- Privy (auth + embedded wallets) ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_VERIFICATION_KEY=

# --- Sumsub KYC (Phase 2; optional for the WhatsApp MVP) ---
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_WEBHOOK_SECRET=

# --- Twilio WhatsApp ---
# Sandbox during dev: TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Auth model:
#   - TWILIO_AUTH_TOKEN: master token, ONLY used for webhook signature verify
#   - TWILIO_API_KEY_SID/SECRET (SK...): scoped, used for outbound message send
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- LLM provider (Kimi K2) ---
# Pick one of moonshot or groq via LLM_PROVIDER. Both keys can coexist.
#   moonshot: direct API to Moonshot, e.g. KIMI_MODEL=kimi-k2-0905-preview
#   groq:     same Kimi model on Groq's infra, e.g. KIMI_MODEL=moonshotai/kimi-k2-instruct
LLM_PROVIDER=moonshot
MOONSHOT_API_KEY=
GROQ_API_KEY=
KIMI_MODEL=kimi-k2-0905-preview

# --- ElevenLabs (Phase 2 voice; optional) ---
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# --- Helius (Solana RPC + enhanced webhooks) ---
HELIUS_API_KEY=
HELIUS_WEBHOOK_SECRET=

# --- Database (Supabase Postgres recommended) ---
# Use `?pgbouncer=true&connection_limit=1` on DATABASE_URL for serverless.
# DIRECT_URL bypasses pgbouncer for migrations (drizzle-kit).
DATABASE_URL=postgresql://user:pass@localhost:5432/comadre
DIRECT_URL=postgresql://user:pass@localhost:5432/comadre

# --- Redis (Upstash REST) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Internal auth (service-to-service HMAC) ---
# Generate with: openssl rand -hex 32
INTERNAL_HMAC_SECRET=

# --- Service URLs (internal mesh) ---
API_URL=http://localhost:3001
WA_URL=http://localhost:3002
AGENT_URL=http://localhost:3003
INDEXER_URL=http://localhost:3004

# --- Observability (optional) ---
SENTRY_DSN=
BETTER_STACK_TOKEN=

# --- Dev tooling (optional) ---
# ngrok for exposing local webhooks to Twilio during dev
NGROK_AUTH_TOKEN=

# --- App ---
NODE_ENV=development
LOG_LEVEL=debug
