{
  "compilerOptions": {
    "types": ["mocha", "node", "chai"],
    "typeRoots": ["./node_modules/@types"],
    "lib": ["es2022"],
    "module": "commonjs",
    "target": "es2022",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./target/ts"
  },
  "include": ["tests/**/*.ts"]
}
