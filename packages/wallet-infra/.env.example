# wallet-infra environment — copy to apps/api/.env.local or repo-root .env.local
# All vars are required for runtime; missing → hard fail at process startup via Zod.

# ── Chain ────────────────────────────────────────────────────────────────────
MONAD_CHAIN_ID=10143
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# ── Privy (owner EOAs + onboarding JWT verification) ─────────────────────────
PRIVY_APP_ID=cl...
PRIVY_APP_SECRET=...

# ── Pimlico (ERC-4337 bundler + paymaster) ───────────────────────────────────
PIMLICO_API_KEY=pim_...
# "true" = sponsor gas via paymaster; "false" = smart wallet pays MON.
PIMLICO_PAYMASTER_ENABLED=true

# ── AWS KMS (session-key envelope encryption) ────────────────────────────────
# For local dev without real AWS, use LocalStack or skip KMS-dependent tests.
# See packages/wallet-infra/README.md "Local dev" section.
AWS_REGION=us-east-1
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/00000000-0000-0000-0000-000000000000

# ── On-chain Comadre contracts (filled once deployed to Monad testnet) ───────
COMADRE_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=

# ── Twilio (SMS magic-link + Verify OTP) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SERVICE_SID=VA...
# Used by /api/v1/onboarding/monad/start to send the magic link.
TWILIO_SMS_FROM=+15555550100

# ── Onboarding web page ──────────────────────────────────────────────────────
ONBOARDING_BASE_URL=https://comadre.app
