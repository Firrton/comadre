# Required for forge script deploys (load via `source .env`).
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC=https://rpc.monad.xyz

# Deploy actors — Comadre operational roles.
# Use `cast wallet import` to store the deployer key encrypted in ~/.foundry/keystores
# and pass `--account <name>` to `forge script`. NEVER put plaintext keys in this file.
KYC_ORACLE=0x0000000000000000000000000000000000000000
CRANK_AUTHORITY=0x0000000000000000000000000000000000000000
FEE_DESTINATION=0x0000000000000000000000000000000000000000

# Protocol params (set in initial deploy).
FEE_BPS=50
KYC_LIMIT_T0=0
KYC_LIMIT_T1=200000000
KYC_LIMIT_T2=2000000000
KYC_LIMIT_T3=20000000000

# Filled after MockUSDC deploy on testnet; on mainnet, the canonical USDC address.
USDC_ADDRESS=0x0000000000000000000000000000000000000000
